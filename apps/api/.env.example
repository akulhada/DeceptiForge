# Purpose: template API runtime configuration. Responsibilities: enumerate all currently required environment variables. Future modules: add credentials only when the owning integration is introduced.
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://deceptiforge:replace-with-a-local-development-password@localhost:5432/deceptiforge
# Allow the local dashboard origin during development.
CORS_ORIGINS=["http://localhost:3000"]
# Mount /demo/* routes and permit local-path scanning. Keep false outside local demos.
DEMO_ENABLED=true
# Organization/API-key boundary. AUTH_ENABLED=false (development/demo only) bypasses to the demo
# organization so the local dashboard works without headers. In production keep it true and bind
# API keys to organizations with API_KEY_BINDINGS (JSON), then send X-DeceptiForge-API-Key.
AUTH_ENABLED=false
DEMO_API_KEY=local-development-key
# Example production binding: {"replace-with-key":"00000000-0000-0000-0000-0000000000de"}
API_KEY_BINDINGS={}
# Reuse a narrative for the same incident/context within this window instead of regenerating.
NARRATIVE_COOLDOWN_SECONDS=30
# GPT incident narratives. The feature works without a key (deterministic fallback); a key only
# enables the model-written summary. Leave OPENAI_API_KEY empty to demo without OpenAI.
INCIDENT_NARRATIVE_ENABLED=true
OPENAI_API_KEY=
OPENAI_INCIDENT_MODEL=gpt-4o-mini
# Rate limiting. "app" uses the in-process limiter (single worker only); "gateway" delegates to an
# edge/reverse-proxy. Production with "app" requires REDIS_URL, else startup fails.
RATE_LIMIT_MODE=app
REDIS_URL=
# Abuse/resource limits and retention (see docs/SecurityModel.md, docs/Deployment.md).
CORS_ALLOW_CREDENTIALS=false
MAX_REQUEST_BODY_BYTES=1048576
MONITORING_MAX_VALUE_BYTES=65536
MONITORING_TIMESTAMP_SKEW_SECONDS=300
INCIDENT_STALE_AFTER_SECONDS=86400
NARRATIVE_REVISION_RETENTION_COUNT=20
# Capacity management is opt-in until staging certification records measured coefficients. Redis is
# required when enabled so tenant quotas are shared across API replicas.
CAPACITY_MANAGEMENT_ENABLED=false
PERFORMANCE_TESTING_ENABLED=false
DEFAULT_TENANT_TIER=small
MONITORING_MAX_EVENTS_PER_SECOND=20
MONITORING_MAX_BURST=50
TENANT_MAX_PENDING_JOBS=1000
TENANT_MAX_CONCURRENT_SCANS=2
TENANT_MAX_CONCURRENT_DEPLOYMENTS=2
TENANT_MAX_REPORT_JOBS=2
WORKER_PRIORITY_RESERVE_PERCENT=30
API_DATABASE_POOL_SIZE=10
WORKER_DATABASE_POOL_SIZE=5
QUEUE_BACKLOG_ALERT_SECONDS=300
CAPACITY_HEADROOM_PERCENT=40
PERFORMANCE_METHODOLOGY_VERSION=performance-v1
