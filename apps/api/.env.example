# Purpose: template API runtime configuration. Responsibilities: enumerate all currently required environment variables. Future modules: add credentials only when the owning integration is introduced.
APP_ENV=development
LOG_LEVEL=INFO
DATABASE_URL=postgresql+psycopg://deceptiforge:replace-with-a-local-development-password@localhost:5432/deceptiforge
# Allow the local dashboard origin during development.
CORS_ORIGINS=["http://localhost:3000"]
# Mount /demo/* routes and permit local-path scanning. Keep false outside local demos.
DEMO_ENABLED=true
# Organization/API-key boundary. AUTH_ENABLED=false (development/demo only) bypasses to the demo
# organization so the local dashboard works without headers. In production keep it true and bind
# API keys to organizations with API_KEY_BINDINGS (JSON), then send X-DeceptiForge-API-Key.
AUTH_ENABLED=false
DEMO_API_KEY=local-development-key
# Example production binding: {"replace-with-key":"00000000-0000-0000-0000-0000000000de"}
API_KEY_BINDINGS={}
# Reuse a narrative for the same incident/context within this window instead of regenerating.
NARRATIVE_COOLDOWN_SECONDS=30
# GPT incident narratives. The feature works without a key (deterministic fallback); a key only
# enables the model-written summary. Leave OPENAI_API_KEY empty to demo without OpenAI.
INCIDENT_NARRATIVE_ENABLED=true
OPENAI_API_KEY=
OPENAI_INCIDENT_MODEL=gpt-4o-mini
