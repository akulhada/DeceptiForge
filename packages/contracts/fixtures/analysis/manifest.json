      }
    },
    {
      "id": "k8s-microservices",
      "name": "Kubernetes microservices repository",
      "description": "Many independently named services with Kubernetes and CI/CD.",
      "file": "06-k8s-microservices.json",
      "expected": {
        "repository_type": ["microservices", "monorepo", "service-oriented"],
        "service_architecture": "microservices",
        "sensitive_zone_categories": ["deployment", "infrastructure"],
        "overall_confidence_min": 0.45
      }
    },
    {
      "id": "monorepo",
      "name": "Monorepo (multiple domains)",
      "description": "Several applications across distinct business domains in one repository.",
