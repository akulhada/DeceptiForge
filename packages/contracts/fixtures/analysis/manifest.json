{
  "schema": "analysis-signals-v1",
  "note": "Fictional, deterministic scenario fixtures for the Interactive Demo Lab. No real secrets or organizations. Shared by backend inference tests and the frontend scenario selector.",
  "scenarios": [
    {
      "id": "fintech-payments",
      "name": "Fintech / payment platform",
      "description": "Payment processing with reconciliation, settlement, and PCI-sensitive services.",
      "file": "01-fintech-payments.json",
      "expected": {
        "business_domain": "fintech",
        "repository_type": ["microservices", "service-oriented", "monorepo"],
        "key_vocabulary": ["payment", "settlement", "reconciliation"],
        "sensitive_zone_categories": ["payment", "billing", "secrets_and_credentials"],
        "recommendation_zone_types": ["environment_file", "example_environment_file", "config_file", "documentation_file"],
        "warning_codes_absent": ["sparse_input", "no_business_domain"],
        "overall_confidence_min": 0.5,
        "data_sensitivity": "high"
      }
    },
    {
      "id": "saas-crm",
      "name": "SaaS customer-management system",
      "description": "Multi-tenant CRM with subscriptions, accounts, support, and admin.",
      "file": "02-saas-crm.json",
      "expected": {
        "business_domain": "saas_crm",
        "key_vocabulary": ["tenant", "subscription", "account"],
        "sensitive_zone_categories": ["customer_data", "support_operations", "administration"],
        "warning_codes_absent": ["sparse_input"],
        "overall_confidence_min": 0.45
      }
    },
    {
      "id": "healthcare",
      "name": "Healthcare application",
      "description": "Clinical scheduling and claims with regulated-data sensitivity.",
      "file": "03-healthcare.json",
      "expected": {
        "business_domain": "healthcare",
        "key_vocabulary": ["patient", "clinical", "claims"],
        "sensitive_zone_categories": ["customer_data", "compliance_documentation"],
        "warning_codes_present": ["no_infrastructure"],
        "overall_confidence_max": 0.75,
        "data_sensitivity": "high"
      }
    },
    {
      "id": "ecommerce",
      "name": "E-commerce platform",
      "description": "Catalog, orders, checkout, fulfillment, and inventory.",
      "file": "04-ecommerce.json",
      "expected": {
        "business_domain": "ecommerce",
        "key_vocabulary": ["catalog", "order", "checkout"],
        "sensitive_zone_categories": ["payment", "customer_data", "support_operations"],
        "overall_confidence_min": 0.45
      }
    },
    {
      "id": "ml-rag",
      "name": "Data / ML platform with RAG",
      "description": "Model pipelines, embeddings, vector store, and RAG retrieval surfaces.",
      "file": "05-ml-rag.json",
      "expected": {
        "business_domain": "ml_data",
