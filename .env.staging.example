# Purpose: template for a controlled-staging deployment of DeceptiForge.
# Copy to a location your secret manager renders (NOT committed) and fill placeholders. This file
# contains placeholders only — never commit real secrets. Values below are the production-shaped
# settings the staging preflight enforces.

# --- environment ---------------------------------------------------------------------------------
APP_ENV=staging
AUTH_ENABLED=true
DEMO_ENABLED=false

# --- database (private network; supply via secret manager) ---------------------------------------
POSTGRES_DB=deceptiforge
POSTGRES_USER=deceptiforge
POSTGRES_PASSWORD=__from_secret_manager__
DATABASE_URL=postgresql+psycopg://deceptiforge:__from_secret_manager__@postgres:5432/deceptiforge

# --- distributed ingestion safety (Redis required, private network) ------------------------------
REDIS_URL=redis://redis:6379/0
RATE_LIMIT_MODE=app
RATE_LIMIT_BACKEND=redis
REPLAY_BACKEND=redis
REDIS_FAIL_MODE=closed

# --- signed monitor ingestion (mandatory outside development) ------------------------------------
MONITOR_SIGNATURE_REQUIRED=true

# --- evidence encryption (supply key via secret manager) -----------------------------------------
EVIDENCE_ENCRYPTION_MODE=local
EVIDENCE_ENCRYPTION_KEY=__from_secret_manager__

# --- bootstrap keys: disabled in steady state ----------------------------------------------------
BOOTSTRAP_KEYS_ENABLED=false
# API_KEY_BINDINGS intentionally unset. Open a time-boxed window only to mint the first owner key,
# then remove it and restart (see docs/bootstrap-and-encryption.md).

# --- CORS: explicit origins only (fail-closed) ---------------------------------------------------
CORS_ORIGINS=["https://staging-dashboard.example.com"]
CORS_ALLOW_CREDENTIALS=false

# --- ingress (documented; enforced at the reverse proxy, not here) -------------------------------
# Terminate TLS at the proxy; set a request body-size limit (~1 MiB) matching MAX_REQUEST_BODY_BYTES.
