# Purpose: template local infrastructure environment. Responsibilities: provide required Compose variables without secrets. Future modules: application-specific templates live in each app directory.
POSTGRES_DB=deceptiforge
POSTGRES_USER=deceptiforge
POSTGRES_PASSWORD=replace-with-a-local-development-password
POSTGRES_PORT=5432
API_PORT=8000

# --- Distributed ingestion safety (multi-worker production) ---------------------------------------
# Development may use in-memory backends (single worker only). Production must use Redis-backed
# rate limiting (or RATE_LIMIT_MODE=gateway) and Redis-backed replay protection.
REDIS_URL=
RATE_LIMIT_MODE=app            # app | gateway
RATE_LIMIT_BACKEND=memory      # memory | redis
REPLAY_BACKEND=memory          # memory | redis
REDIS_KEY_PREFIX=deceptiforge
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_CONNECT_TIMEOUT_SECONDS=2
REDIS_FAIL_MODE=closed         # closed (reject on outage) | open (degrade to allow)

# Require HMAC-signed (monitor-signature-v1) monitoring ingestion. Enable in production once
# monitor credentials are provisioned (see docs/monitor-signing.md).
MONITOR_SIGNATURE_REQUIRED=false

# --- Evidence encryption boundary -----------------------------------------------------------------
EVIDENCE_ENCRYPTION_MODE=disabled   # disabled (dev only) | local | kms (documented strategy)
EVIDENCE_ENCRYPTION_KEY=

# --- Bootstrap API keys (see docs) ----------------------------------------------------------------
BOOTSTRAP_KEYS_ENABLED=false
