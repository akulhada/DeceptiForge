# Purpose: exclude generated, local, and secret files from Git. Responsibilities: keep commits reproducible and credential-free. Future modules: add only tool-specific generated paths.
node_modules/
.pnpm-store/
.turbo/
.next/
# Second dev server's build output (see distDir in apps/web/next.config.ts).
.next-judge/
# Regenerated by whichever dev server runs last, and it points at that server's distDir —
# committing it makes the two dev servers fight over the file.
apps/web/next-env.d.ts
dist/
.plasmo/
apps/extension/build/
coverage/

.venv/
__pycache__/
*.py[cod]
.pytest_cache/
.mypy_cache/
.ruff_cache/

.env
.env.*
!.env.example
!.env.staging.example

.DS_Store
*.tsbuildinfo
.env.local

# pnpm monorepo — reject non-pnpm lockfiles that break Next workspace-root inference
package-lock.json
yarn.lock

# Local agent tooling state: settings, launch config, and worktrees are developer-local and must
# never ship in a release artifact.
.claude/

# Generated Python packaging metadata and build output: regenerated by every install, must not be
# tracked or shipped.
*.egg-info/
apps/api/build/
