# Purpose: standardize basic editor behavior. Responsibilities: maintain consistent whitespace and line endings. Future modules: language-specific rules belong beside their tools.
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2

[*.py]
indent_size = 4

[Makefile]
indent_style = tab
